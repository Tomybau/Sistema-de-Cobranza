# =============================================================================
# Sistema de Cobranza — Variables de entorno
# Copiar a .env y completar con valores reales. NUNCA commitear .env
# =============================================================================

# Base de datos
DATABASE_URL="postgresql://cobranza:cobranza@localhost:5432/cobranza?schema=public"

# Auth.js (NextAuth v5)
# Generar con: openssl rand -base64 32
AUTH_SECRET="cambiar-en-prod-generar-con-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Resend (envío de mails)
# https://resend.com/api-keys
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="cobranza@tudominio.com"
RESEND_FROM_NAME="Cobranza"
# Webhook signing secret (Resend Dashboard → Webhooks → Signing Secret)
RESEND_WEBHOOK_SECRET=""

# Storage (MinIO en dev, S3 o R2 en prod)
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_REGION="us-east-1"
STORAGE_BUCKET="cobranza-documents"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_FORCE_PATH_STYLE="true"

# App
NODE_ENV="development"
APP_URL="http://localhost:3000"
APP_TIMEZONE="America/Argentina/Buenos_Aires"
APP_DEFAULT_CURRENCY="USD"

# Logging
LOG_LEVEL="info"

